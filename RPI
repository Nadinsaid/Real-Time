#!/usr/bin/env python3
"""
ECE 612 Raspberry Pi Alarm Decision Manager

Purpose:
  - Subscribe to Arduino Nano 33 IoT sensor/status JSON over Mosquitto.
  - Parse the sensor package.
  - Decide the output commands for fan, RGB LED, buzzer, and display status.
  - Publish a compact command JSON back to the Arduino.

Expected Arduino publish topic:
  ece612/<GNUMBER>/nano33iot/sensors

Expected Pi command topic:
  ece612/<GNUMBER>/pi/commands

Run on the Raspberry Pi that is hosting Mosquitto:
  python3 pi_alarm_controller.py
"""

from __future__ import annotations

import json
import signal
import sys
import time
from dataclasses import dataclass
from typing import Any, Dict, List, Optional

try:
    import paho.mqtt.client as mqtt
except ImportError:
    print("Missing dependency: paho-mqtt")
    print("Install it with one of these commands on the Pi:")
    print("  sudo apt install python3-paho-mqtt")
    print("or:")
    print("  python3 -m pip install paho-mqtt")
    sys.exit(1)


# ----------------------------
# Project configuration
# ----------------------------
GNUMBER = "Gxxxx9820"          # Must match const char gNumber[] in the Arduino sketch.
BROKER_HOST = "localhost"      # Use localhost when this script runs on the Mosquitto Pi.
BROKER_PORT = 1883
CLIENT_ID = f"pi_alarm_controller_{GNUMBER}"

TOPIC_SENSORS = f"ece612/{GNUMBER}/nano33iot/sensors"
TOPIC_COMMANDS = f"ece612/{GNUMBER}/pi/commands"
TOPIC_PI_STATUS = f"ece612/{GNUMBER}/pi/status"

# These match the Arduino project logic.
TEMP_THRESHOLD_F = 80.0
TEMP_HYSTERESIS_F = 2.0
GREEN_CONFIRM_TIME_S = 2.0

# Command names are intentionally flat/compact for easier Arduino parsing later.
LED_OFF = "off"
LED_SOLID_RED = "solid_red"
LED_BLINK_RED = "blink_red"
LED_SOLID_WHITE = "solid_white"
LED_SOLID_GREEN = "solid_green"

BUZZER_OFF = "off"
BUZZER_ON_PIR = "on_pir"
BUZZER_BEEP_PIR = "beep_pir"
BUZZER_BEEP_TEMP = "beep_temp"
BUZZER_BEEP_POWER = "beep_power"


@dataclass
class ControllerState:
    """State kept on the Pi so it can detect transitions between messages."""

    command_sequence: int = 0
    last_sensor_message_number: Optional[int] = None
    last_alarm_active: Optional[bool] = None
    last_alarm_lockout: Optional[bool] = None
    last_system_armed: Optional[bool] = None
    green_confirm_until: float = 0.0
    last_fan_command: int = 0


state = ControllerState()
client: Optional[mqtt.Client] = None


def as_bool(value: Any) -> bool:
    """Convert JSON values that may arrive as bool, int, float, or string."""
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return value != 0
    if isinstance(value, str):
        return value.strip().lower() in {"1", "true", "yes", "on", "high", "motion"}
    return False


def as_float(value: Any, default: float = 0.0) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return default


def as_int(value: Any, default: int = 0) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def decide_outputs(sensor: Dict[str, Any], now: float) -> Dict[str, Any]:
    """
    Decide what commands the Arduino outputs should use.

    Priority order:
      1. PIR/security alarm
      2. Short green confirmation after an alarm/armed-state clear
      3. High temperature
      4. Power failure / darkness
      5. Normal/off
    """
    reasons: List[str] = []

    message_number = as_int(sensor.get("messageNumber"), default=-1)

    motion_detected = as_bool(sensor.get("motionDetected", sensor.get("pir", 0)))
    power_failure = as_bool(sensor.get("powerFailure", False))
    dht_read_ok = as_bool(sensor.get("dhtReadOk", True))
    high_temp_flag = as_bool(sensor.get("highTemp", False))
    temperature_f = as_float(sensor.get("temperatureF"), default=0.0)
    system_armed = as_bool(sensor.get("systemArmed", False))
    alarm_active_from_arduino = as_bool(sensor.get("alarmActive", False))
    alarm_lockout = as_bool(sensor.get("alarmLockout", False))

    # The Arduino currently still owns the keypad/password state. The Pi can
    # still infer a PIR alarm if it sees armed + motion before the next Arduino
    # status message updates alarmActive.
    pir_alarm = alarm_active_from_arduino or (system_armed and motion_detected)

    # Detect a transition that deserves a brief green LED confirmation.
    # This catches: alarm active -> clear, lockout -> clear, or armed-state toggle.
    first_message = state.last_alarm_active is None
    if not first_message:
        alarm_was_cleared = (state.last_alarm_active or state.last_alarm_lockout) and not pir_alarm and not alarm_lockout
        armed_state_toggled = state.last_system_armed != system_armed
        if alarm_was_cleared or armed_state_toggled:
            state.green_confirm_until = now + GREEN_CONFIRM_TIME_S
            reasons.append("green_confirm_transition")

    # Use Arduino highTemp when available because Arduino already applies hysteresis.
    # If highTemp is absent in a future payload, fall back to the raw temperature.
    if "highTemp" in sensor:
        high_temp = high_temp_flag
    else:
        high_temp = dht_read_ok and temperature_f >= TEMP_THRESHOLD_F

    # Fan command. If the DHT read fails, keep the previous fan command instead
    # of rapidly turning the fan on/off because the temperature input is invalid.
    if dht_read_ok:
        fan = 1 if high_temp else 0
        state.last_fan_command = fan
    else:
        fan = state.last_fan_command
        reasons.append("dht_read_error_keep_previous_fan")

    # LED and buzzer commands.
    alarm_state = "none"
    led = LED_OFF
    buzzer = BUZZER_OFF
    display = "NORMAL"

    if alarm_lockout:
        alarm_state = "lockout"
        led = LED_SOLID_RED
        buzzer = BUZZER_ON_PIR
        display = "ALARM LOCKOUT"
        reasons.append("pir_alarm_lockout")
    elif pir_alarm:
        alarm_state = "active"
        led = LED_BLINK_RED
        buzzer = BUZZER_BEEP_PIR
        display = "ALARM ACTIVE"
        reasons.append("armed_motion_alarm")
    elif now < state.green_confirm_until:
        led = LED_SOLID_GREEN
        buzzer = BUZZER_OFF
        display = "CONFIRMED"
        reasons.append("green_confirmation")
    elif high_temp:
        led = LED_SOLID_RED
        buzzer = BUZZER_BEEP_TEMP
        display = "HIGH TEMP"
        reasons.append("high_temperature")
    elif power_failure:
        led = LED_SOLID_WHITE
        buzzer = BUZZER_BEEP_POWER
        display = "POWER FAILURE"
        reasons.append("power_failure")
    else:
        led = LED_OFF
        buzzer = BUZZER_OFF
        display = "NORMAL"
        reasons.append("normal")

    state.command_sequence += 1
    state.last_sensor_message_number = message_number
    state.last_alarm_active = pir_alarm
    state.last_alarm_lockout = alarm_lockout
    state.last_system_armed = system_armed

    command = {
        "src": "pi",
        "gnumber": GNUMBER,
        "seq": state.command_sequence,
        "srcMsg": message_number,
        "ts": int(now),
        "fan": fan,
        "led": led,
        "buzzer": buzzer,
        "alarm": alarm_state,
        "armed": 1 if system_armed else 0,
        "display": display,
        "reason": "+".join(reasons),
    }
    return command


def publish_status(text: str) -> None:
    if client is None:
        return
    status = {
        "src": "pi",
        "gnumber": GNUMBER,
        "ts": int(time.time()),
        "status": text,
    }
    client.publish(TOPIC_PI_STATUS, json.dumps(status), qos=1, retain=True)


def on_connect(client_obj: mqtt.Client, userdata: Any, flags: Any, reason_code: Any, properties: Any = None) -> None:
    print(f"Connected to MQTT broker {BROKER_HOST}:{BROKER_PORT}; result={reason_code}")
    client_obj.subscribe(TOPIC_SENSORS, qos=1)
    print(f"Subscribed to: {TOPIC_SENSORS}")
    print(f"Publishing commands to: {TOPIC_COMMANDS}")
    publish_status("online")


def on_disconnect(client_obj: mqtt.Client, userdata: Any, reason_code: Any, properties: Any = None) -> None:
    print(f"Disconnected from MQTT broker; result={reason_code}")


def on_message(client_obj: mqtt.Client, userdata: Any, msg: mqtt.MQTTMessage) -> None:
    raw_payload = msg.payload.decode("utf-8", errors="replace")

    try:
        sensor = json.loads(raw_payload)
    except json.JSONDecodeError as exc:
        print(f"Bad JSON on {msg.topic}: {exc}; payload={raw_payload}")
        return

    now = time.time()
    command = decide_outputs(sensor, now)
    command_json = json.dumps(command, separators=(",", ":"))

    # Retain is false because some commands, especially green confirmation,
    # are momentary. The Arduino will get a fresh command every sensor message.
    client_obj.publish(TOPIC_COMMANDS, command_json, qos=1, retain=False)

    print(f"RX {msg.topic}: {raw_payload}")
    print(f"TX {TOPIC_COMMANDS}: {command_json}")


def make_client() -> mqtt.Client:
    # Supports both paho-mqtt 1.x and 2.x.
    try:
        mqtt_client = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2, client_id=CLIENT_ID)
    except (AttributeError, TypeError):
        mqtt_client = mqtt.Client(client_id=CLIENT_ID)

    mqtt_client.on_connect = on_connect
    mqtt_client.on_disconnect = on_disconnect
    mqtt_client.on_message = on_message
    mqtt_client.reconnect_delay_set(min_delay=1, max_delay=30)
    return mqtt_client


def shutdown(signum: int, frame: Any) -> None:
    print("Stopping Pi alarm controller...")
    publish_status("offline")
    if client is not None:
        client.disconnect()
    sys.exit(0)


def main() -> None:
    global client

    signal.signal(signal.SIGINT, shutdown)
    signal.signal(signal.SIGTERM, shutdown)

    client = make_client()
    print("ECE 612 Pi Alarm Controller starting")
    print(f"Broker: {BROKER_HOST}:{BROKER_PORT}")
    print(f"Sensor topic: {TOPIC_SENSORS}")
    print(f"Command topic: {TOPIC_COMMANDS}")

    # connect_async + loop_forever gives automatic reconnect behavior.
    client.connect_async(BROKER_HOST, BROKER_PORT, keepalive=60)
    client.loop_forever(retry_first_connection=True)


if __name__ == "__main__":
    main()
